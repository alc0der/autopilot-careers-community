{
  "name": "@autopilot/renderer",
  "version": "2.2.0",
  "description": "Headless Markdown-to-PDF resume renderer",
  "bin": {
    "oh-my-cv-render": "bundle/oh-my-cv-render.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "bundle": "node esbuild.config.mjs",
    "build": "pnpm typecheck && pnpm bundle",
    "mcp": "node bundle/oh-my-cv-render-mcp.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^23.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "commander": "^11.0.0",
    "esbuild": "^0.25.0",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-link-attributes": "^4.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
