{
  "name": "autopilot-careers",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "mcp:install": "python3 scripts/claude_mcp.py install",
    "mcp:status": "python3 scripts/claude_mcp.py status",
    "codex:publish": "pnpm --dir packages/agent-marketplace codex:publish"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "puppeteer"
    ]
  }
}
